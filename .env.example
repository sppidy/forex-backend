# Copy to `.env` and fill in. NEVER commit your `.env`.

# === Database (PostgreSQL) ===
# Used by the docker-compose stack at the super-repo level.
POSTGRES_USER=forex
POSTGRES_PASSWORD=
POSTGRES_DB=forex
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# === Auth ===
# Bootstrap admin token for first-time setup. Strong random string.
ADMIN_API_KEY=

# === LLM providers (cascade) ===
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
OLLAMA_BASE_URL=
OLLAMA_MODEL=nemotron-3-nano:4b
